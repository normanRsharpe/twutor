# Twutor app service
# Railway sets this through a service reference to the Postgres plugin.
DATABASE_URL=

# Better Auth. Generate a stable high-entropy secret; never commit the real value.
BETTER_AUTH_SECRET=
# Exact public origin, without /api/auth. HTTPS is required outside localhost.
BETTER_AUTH_URL=http://localhost:3000

# Local development only. Production ignores this flag even if set.
TWUTOR_DEMO_MODE=false

# Production safety gate. Leave false until TWU-44 scopes every learner-owned read and write.
TWUTOR_MULTI_USER_ENABLED=false
# Comma-separated immutable Better Auth user IDs; email addresses are not authorization keys.
TWUTOR_ADMIN_USER_IDS=
